# LinkedIn credentials (para auto-renovación de sesión cuando expira)
LINKEDIN_EMAIL=tu_email@linkedin.com
LINKEDIN_PASSWORD=tu_password

# Anthropic API Key (para generación de cover letters con IA)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Email destino para cover letters (solo este, no los otros destinatarios)
EMAIL_COVER_LETTER=tu_email_personal@example.com

BASE_URL=https://example.com
API_BASE_URL=https://api.example.com
API_TOKEN=your_token_here
ENVIRONMENT=qa
HEADLESS=true

# Twilio Configuration for WhatsApp Notifications
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio WhatsApp sandbox number
WHATSAPP_TO=whatsapp:+573202552580  # Your personal WhatsApp number
WHATSAPP_ENABLED=true                # Set to false to disable WhatsApp notifications (emails still sent)

# Cron schedule — cada hora de 7am a 7pm, lunes a viernes
CRON_SCHEDULE=0 7-19 * * 1-5

# Scraper tuning
MAX_PAGES_PER_SEARCH=3   # Pages to fetch per keyword/location (25 jobs/page). Default: 3 → up to 75 results
MIN_SCORE=10             # Minimum relevance score to include a job (applies to all locations). Default: 10

# Search keywords (comma-separated)
# Include both English and Spanish QA terms
SEARCH_KEYWORDS=qa,quality assurance,quality engineer,testing,sdet,automation,analista qa,ingeniero qa,pruebas,automatización,calidad de software

# Search locations (on-site, hybrid, or location-based remote)
# Prioriza ciudades colombianas principales
SEARCH_LOCATIONS=Bogotá,Medellín,Cali,Barranquilla,Cartagena,Cúcuta,Bucaramanga,Colombia

# Search locations remote (remote jobs searchable by region)
# Focus on nearshore-friendly regions
SEARCH_LOCATIONS_REMOTE=Bogotá (remote),Colombia (remote),Latin America (remote)

# Email notification recipients (comma-separated)
EMAIL_TO=tu_email@example.com

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_PORT=587
